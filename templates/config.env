# Per-task config for gdcc. Sourced as bash — arrays and comments are fine.

# --- Model policy (per role). Rules: never haiku; fable ONLY for the planner;
#     non-planner ceiling = opus; floor for everyone = sonnet. ---
GDCC_MODEL_PLANNER="fable"    # ONLY goal-planner may use fable 5
GDCC_MODEL_STRONG="opus"      # ceiling for non-planner roles (auditor/verifier/designer/analyst/decider/reviewer)
GDCC_MODEL_WORKER="sonnet"    # goal-worker normal; escalates to opus on stall/re-plan (never above opus)

# --- Worker loop (loop B) ---
GDCC_MODEL=""                 # headless gdcc run's single worker model ("" = inherit); in-conversation uses the matrix above
GDCC_MAX_ITERS=100            # hard cap on iterations (also caps the Stop-hook)
GDCC_ITER_TIMEOUT=1800        # seconds per iteration (0 = unlimited)
GDCC_MAX_DURATION=0           # wall-clock cap for a whole `gdcc run`, seconds (0 = off)
GDCC_STALL_LIMIT=5            # bail if the criteria output is unchanged this many rounds
GDCC_NOPROGRESS_LIMIT=3       # bail if the repo tree is unchanged this many rounds
GDCC_COMMIT=1                 # snapshot each iteration with git (recommended)

# --- Completion (pass^k) ---
# Require the criteria to pass this many times in a row before declaring the goal
# done. >1 defeats a flaky judge or a lucky single pass — important when CRITERIA.sh
# uses `soft`/`gdcc judge` (LLM checks are non-deterministic). Costs k judge runs.
GDCC_CONSECUTIVE_PASSES=2

# --- Soft criteria (gdcc judge) ---
GDCC_JUDGE_MODEL=""           # model for the strict independent verifier ("" = inherit)
GDCC_JUDGE_TIMEOUT=300        # seconds per soft judgment

# --- Permissions / safety ---
# acceptEdits auto-accepts file edits; the allowlist lets tools run without prompts.
# For FULLY unattended long runs you may set bypassPermissions — only in a disposable
# repo / sandbox with no secrets (see README safety section).
GDCC_PERMISSION_MODE="acceptEdits"
GDCC_ALLOWED_TOOLS=(Read Edit Write Grep Glob Bash Task TodoWrite)
GDCC_SAFETY_PROFILE="standard"  # standard | strict (strict also blocks force-push/hard-reset)

# --- Autonomy (in-conversation unattended; the auto-decide hook) ---
GDCC_AUTO_DECIDE=1            # on: intercept the main agent's questions so a run never pauses
GDCC_AUTO_DECIDE_CAP=25       # after this many interceptions, let the question reach the human (loop guard)
GDCC_PANEL_SIZE=3             # reachability-reviewer subagents the main agent spawns on goal-affecting forks
# Goal changes are NEVER auto-applied: the panel must prove unreachability, and even then
# the loop ESCALATES to you rather than relaxing the goal. (No auto-relax knob by design.)
# The decider + reviewers are Task subagents (goal-decider / reachability-reviewer);
# their model follows those agents' frontmatter, not a config knob.

# --- Quota-aware (reads claude-hud's usage cache; best-effort, needs claude-hud) ---
# When the 5-hour usage window climbs, gdcc run downgrades the worker model; near the
# ceiling it sleeps until the window resets, then resumes. No-op if the cache is absent.
GDCC_MODEL_LOW="sonnet"       # quota-downgrade floor (never haiku)
GDCC_QUOTA_DOWNGRADE_AT=80    # 5h util% at/above which the worker drops to GDCC_MODEL_LOW
GDCC_QUOTA_PAUSE_AT=97        # 5h util% at/above which gdcc run sleeps until the window resets
GDCC_QUOTA_SLEEP=1           # 1: sleep-until-reset at the pause threshold
GDCC_QUOTA_GATE=1            # 1: PreToolUse gate halts ALL work the moment 5h usage >= pause threshold
                            #    (interrupts a running worker at its next tool call; ~5min data-freshness floor)
# GDCC_QUOTA_SOURCE=~/.claude/plugins/claude-hud/.usage-cache.json   # override the cache path

# --- Audit (criteria calibration) ---
GDCC_CRITERIA_BUDGET=120      # max seconds for one criteria run (meta 6)
GDCC_DETERMINISM_RUNS=3       # repeat count for the non-flaky check (meta 5)
