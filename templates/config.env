# Per-task config for gdcc. Sourced as bash — arrays and comments are fine.

# --- Model policy (per role). Rules: never haiku; fable ONLY for goal-planner,
#     goal-decider, and goal-brainstormer; everyone else ceiling = opus; floor = sonnet. ---
GDCC_MODEL_DECISION="fable"   # ONLY goal-planner, goal-decider, goal-brainstormer
GDCC_MODEL_STRONG="opus"      # ceiling for everyone else (reachability-reviewer/criteria-auditor/goal-verifier/criteria-designer/goal-analyst) + worker stall-escalation
GDCC_MODEL_WORKER="sonnet"    # goal-worker normal; escalates to opus on stall/re-plan (never above opus)

# --- Worker loop (loop B) ---
GDCC_MODEL=""                 # headless gdcc run's single worker model ("" = inherit); in-conversation uses the matrix above
GDCC_MAX_ITERS=100            # hard cap on iterations (also caps the Stop-hook)
GDCC_ITER_TIMEOUT=1800        # seconds per iteration (0 = unlimited)
GDCC_MAX_DURATION=0           # wall-clock cap for a whole `gdcc run`, seconds (0 = off)
GDCC_STALL_LIMIT=5            # bail if the criteria output is unchanged this many rounds
GDCC_NOPROGRESS_LIMIT=3       # bail if the repo tree is unchanged this many rounds
GDCC_COMMIT=1                 # snapshot each iteration with git (recommended)

# --- In-flight worker gate (only matters if you BACKGROUND worker subagents) ---
# The default loop dispatches workers as blocking Tasks, so the Stop gate only fires
# between iterations — leave these alone. If instead the master backgrounds a worker
# and yields the turn to await it, the gate would otherwise see a torn scoreboard and
# push a duplicate dispatch. With tracking on, the master calls `gdcc worker begin`
# before backgrounding and `gdcc worker end` when it returns; while a marker is live
# the gate DEFERS (allows the yield) instead of blocking. TTL bounds a crashed worker.
GDCC_INFLIGHT_GATE=1          # 1: Stop gate defers while a worker is in flight; 0: ignore markers (old behavior)
GDCC_WORKER_TTL=""            # seconds a worker marker stays "live" ("" = inherit GDCC_ITER_TIMEOUT)

# --- Completion (pass^k) ---
# Require the criteria to pass this many times in a row before declaring the goal
# done. >1 defeats a flaky check (e.g. timing/perf) or a lucky single pass. CRITERIA.sh
# is strictly static, so this mainly guards a workload whose result varies run-to-run.
GDCC_CONSECUTIVE_PASSES=2

# --- Soft judging (final gate only; NOT used by CRITERIA.sh, which is static) ---
# These apply to the standalone `gdcc judge` command (final gate / manual use).
GDCC_JUDGE_MODEL=""           # model for the strict independent verifier ("" = inherit)
GDCC_JUDGE_TIMEOUT=300        # seconds per judgment

# --- Permissions / safety ---
# acceptEdits auto-accepts file edits; the allowlist lets tools run without prompts.
# For FULLY unattended long runs you may set bypassPermissions — only in a disposable
# repo / sandbox with no secrets (see README safety section).
GDCC_PERMISSION_MODE="acceptEdits"
GDCC_ALLOWED_TOOLS=(Read Edit Write Grep Glob Bash Task TodoWrite)
GDCC_SAFETY_PROFILE="standard"  # standard | strict (strict also blocks force-push/hard-reset)

# --- Autonomy (in-conversation unattended; the auto-decide hook) ---
GDCC_AUTO_DECIDE=1            # on: intercept the main agent's questions so a run never pauses
GDCC_AUTO_DECIDE_CAP=25       # after this many interceptions, let the question reach the human (loop guard)
GDCC_PANEL_SIZE=3             # reachability-reviewer subagents the main agent spawns on goal-affecting forks
GDCC_BRAINSTORM_ROUNDS=3      # at a dead-end (re-plan exhausted + VET=BRAINSTORM), spawn goal-brainstormer
                             # (fable) for novel approaches up to this many rounds before escalating to you.
                             # Also available on demand via /goal-driven:brainstorm. 0 = disable auto-brainstorm.
# Goal changes are NEVER auto-applied: the panel must prove unreachability, and even then
# the loop ESCALATES to you rather than relaxing the goal. (No auto-relax knob by design.)
# The decider + reviewers are Task subagents (goal-decider / reachability-reviewer);
# their model follows those agents' frontmatter, not a config knob.

# --- Quota-aware (reads claude-hud's usage cache; best-effort, needs claude-hud) ---
# When the 5-hour usage window climbs, gdcc run downgrades the worker model; near the
# ceiling it sleeps until the window resets, then resumes. No-op if the cache is absent.
GDCC_MODEL_LOW="sonnet"       # quota-downgrade floor (never haiku)
GDCC_QUOTA_DOWNGRADE_AT=80    # 5h util% at/above which the worker drops to GDCC_MODEL_LOW
# Usage data only refreshes ~every 5 min (Anthropic usage API limit) — there is NO real-time
# quota, and nothing can preempt an in-flight call. So leave HEADROOM: pause well before 100%
# so whatever a worker burns before the gate/watch catches it still fits under the ceiling.
GDCC_QUOTA_PAUSE_AT=90        # 5h util% at/above which work halts + waits until the window resets
GDCC_QUOTA_SLEEP=1           # 1: sleep-until-reset at the pause threshold
GDCC_QUOTA_GATE=1            # 1: PreToolUse gate halts ALL work the moment 5h usage >= pause threshold
                            #    (interrupts a running worker at its next tool call; ~5min data-freshness floor)
# GDCC_QUOTA_SOURCE=~/.claude/plugins/claude-hud/.usage-cache.json   # override the cache path

# --- Audit (criteria calibration) ---
# How the criteria (the sensor) get vetted before sealing. The human already approved the criteria
# semantically (WHAT); this checks the SCRIPTS implement it (HOW) — that empty/cheat solutions are
# rejected. Pick by how expensive CRITERIA.sh is to actually run:
GDCC_AUDIT_LEVEL=agent        # agent (default): a read-only SUBAGENT statically reviews CRITERIA.sh + baselines
                              #   (would empty/cheat be rejected? coverage?) WITHOUT executing the workload — fast,
                              #   no project copy. Best when CRITERIA.sh runs a heavy/real workload. Advisory only:
                              #   it reports concerns, the human decides. (Reasoned, not executed — trades proof for speed.)
                              # lite: EXECUTE empty+cheat baselines, both must-FAIL (~2 runs). An executed proof.
                              # full: lite + determinism (DETERMINISM_RUNS x) + reference-must-PASS ceiling.
                              # off:  no audit at all (seal only locks the tamper checksum — NO anti-cheat).
GDCC_AUDIT_EXCLUDE=""         # extra space-separated globs to exclude from the temp copy (lite/full only)
GDCC_CRITERIA_BUDGET=120      # max seconds for one criteria run (lite/full; meta 6)
GDCC_DETERMINISM_RUNS=3       # repeat count for the non-flaky check (full level only; meta 5)
